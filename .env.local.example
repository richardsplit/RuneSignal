# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe — Core subscription plans ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Stripe — Metered add-on price IDs (Evidence Plane) ──────────────────────
# Create these as "Licensed" prices with usage_type=metered in your Stripe dashboard.
# Set STRIPE_METER_ENABLED=true once Billing Meters are created in Stripe Dashboard.
# Usage is always tracked internally regardless of this flag.
# Meter event names must match exactly: evidence_pack_signed, ledger_replay,
# registry_verification, passport_issued
STRIPE_METER_ENABLED=               # Set to 'true' to enable Stripe usage sync

# ── Sentry Error Monitoring ──────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────────
ENABLE_PQC=false   # Activate ML-DSA-65 post-quantum signatures (migration 045)

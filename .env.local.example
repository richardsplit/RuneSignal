# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe — Core subscription plans ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe price IDs (EUR) — created 2026-04-21
STRIPE_PRO_PRICE_ID=price_1TOfaBBpeiNDAhujs1xWtK84
STRIPE_ENTERPRISE_PRICE_ID=price_1TOfiyBpeiNDAhujRTI7xrpL
# Expose to client for billing/page.tsx checkout flow
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_1TOfaBBpeiNDAhujs1xWtK84
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_1TOfiyBpeiNDAhujRTI7xrpL

# ── Stripe — Billing Meters (Evidence Plane) ─────────────────────────────────
# Set to 'true' once all 4 Billing Meters are live in Stripe Dashboard:
#   evidence_pack_signed | decision_ledger_replay | passport_verification | passport_issued
# Internal usage tracking works regardless; this flag enables Stripe sync.
STRIPE_METER_ENABLED=true

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Edge Rate Limiting (Upstash Redis) ───────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Audit Ledger Signing ──────────────────────────────────────────────────────
ATP_SIGNING_KEY=        # Ed25519 private key (base64) for audit event signatures

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_RBAC=false       # Enable RBAC middleware route guard (migration 053)
ENABLE_PQC=false        # Activate ML-DSA-65 post-quantum signatures (migration 045)

# ─── Enterprise SSO ───────────────────────────────────────────────────────────
# Required when tenants configure SSO via /account-settings/sso

# Okta OIDC
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_ISSUER=https://<your-okta-domain>/oauth2/default

# Microsoft Entra (Azure AD)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Auth0
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=<your-tenant>.auth0.com

# ─── Integration Adapters ─────────────────────────────────────────────────────

# Slack App (interactive approve/deny buttons — distinct from incoming webhook)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Microsoft Teams — webhook URL stored per-tenant in integration_channels (no server secret needed)

# Jira (OAuth 2.0)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_BASE_URL=https://<your-org>.atlassian.net

# ServiceNow
SERVICENOW_INSTANCE=https://<your-instance>.service-now.com
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=

# PagerDuty
PAGERDUTY_API_KEY=

# ─── SIEM Export ──────────────────────────────────────────────────────────────
# Used by lib/integrations/siem/exporter.ts
SIEM_ENDPOINT=
SIEM_API_KEY=

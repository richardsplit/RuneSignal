# Sentry Error Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Enterprise SSO ───────────────────────────────────────────────────────────
# Required when tenants configure SSO via /account-settings/sso
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Okta OIDC
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_ISSUER=https://<your-okta-domain>/oauth2/default

# Microsoft Entra (Azure AD)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Auth0
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=<your-tenant>.auth0.com

# ─── Integration Adapters ─────────────────────────────────────────────────────
# Slack App (for interactive approve/deny buttons — distinct from incoming webhook)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Microsoft Teams (incoming webhook — per-tenant config stored in DB)
# No server-side secrets needed; webhook URL is stored per tenant in integration_channels

# Jira (OAuth 2.0 or API token)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_BASE_URL=https://<your-org>.atlassian.net

# ServiceNow
SERVICENOW_INSTANCE=https://<your-instance>.service-now.com
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=

# PagerDuty
PAGERDUTY_API_KEY=

# ─── SIEM Export ─────────────────────────────────────────────────────────────
# Used by lib/integrations/siem/exporter.ts
SIEM_ENDPOINT=
SIEM_API_KEY=
